# LLMGuard Environment Variables
# Copy this file to .env and fill in your keys — never commit .env to git

# API Keys (at least one required to run scans)
CLAUDE_API_KEY= 
OPENAI_API_KEY=

# Flask runtime
FLASK_ENV=development
FLASK_DEBUG=false
PORT=5000

# Rate limiting (requests per window / window in seconds)
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60

# LLM request timeout in seconds
REQUEST_TIMEOUT=30
